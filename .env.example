# Thai Corner API — Miljövariabler
# Kopiera: cp .env.example .env
# Lägg ALDRIG .env i Git

# Port (Render sätter detta automatiskt)
PORT=3000

# Hemlig API-nyckel — Telavox skickar denna i X-API-Key headern
# Generera: openssl rand -hex 32
API_KEY=byt-ut-denna-mot-en-hemlig-nyckel

# PostgreSQL connection string från Neon
# Hämtas från: neon.tech → ditt projekt → Dashboard → Connection string
# Välj "Node.js" i dropdown och kopiera hela raden
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
